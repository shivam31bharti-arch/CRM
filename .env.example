# Application environment variables.
DATABASE_URL="postgresql://crm:crm@postgres:5432/crm?schema=public"
NEXTAUTH_URL="http://localhost:3000"

# Required — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Required for OAuth token encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-openssl-rand-hex-32"

# Required for HMAC API key hashing — generate with: openssl rand -base64 32
API_KEY_SECRET="replace-with-openssl-rand-base64-32"

# Required for the cron scheduler — generate with: openssl rand -base64 32
CRON_SECRET="replace-with-openssl-rand-base64-32"

# ─── Email ──────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_local_placeholder"

# ─── File Uploads ───────────────────────────────────────────────────────────
UPLOADTHING_SECRET="sk_live_placeholder"
UPLOADTHING_APP_ID="local-placeholder"

# ─── Realtime (Pusher) ─────────────────────────────────────────────────────
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# ─── Redis (scheduler queue + caching) ─────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── Twitter / X  (OAuth 2.0) ──────────────────────────────────────────────
# Create at: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# ─── LinkedIn (OAuth 2.0) ──────────────────────────────────────────────────
# Create at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ─── Facebook + Instagram (Meta Graph API) ─────────────────────────────────
# Create at: https://developers.facebook.com/apps
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
