# Application environment variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
NEXTAUTH_URL="http://localhost:3000"

# Required. Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_BASE64_32"
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_BASE64_32"

# Required for OAuth token encryption. Generate with: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_GENERATE_HEX_32_BYTES"

# Required for HMAC API key hashing. Generate with: openssl rand -base64 32
API_KEY_SECRET="CHANGE_ME_GENERATE_BASE64_32"

# Required for the cron scheduler. Generate with: openssl rand -base64 32
CRON_SECRET="CHANGE_ME_GENERATE_BASE64_32"

# Email.
RESEND_API_KEY="CHANGE_ME_RESEND_API_KEY"

# File uploads.
UPLOADTHING_SECRET="CHANGE_ME_UPLOADTHING_SECRET"
UPLOADTHING_APP_ID="CHANGE_ME_UPLOADTHING_APP_ID"

# Realtime (Pusher).
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Redis (scheduler queue + caching).
REDIS_URL="redis://HOST:PORT"

# Twitter / X OAuth 2.0.
# Create at: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# LinkedIn OAuth 2.0.
# Create at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Facebook + Instagram (Meta Graph API).
# Create at: https://developers.facebook.com/apps
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
